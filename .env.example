### VideoDrop — variables de entorno
# Puerto público (lo lee el systemd unit).
AUDIODROP_PORT=3400

# Carpeta de trabajo para descargas temporales (se limpia sola).
AUDIODROP_WORK_DIR=/tmp/audiodrop

# Duración máxima permitida del video (en segundos). 1800 = 30 minutos.
AUDIODROP_MAX_DURATION=1800

# Nivel de logs: DEBUG | INFO | WARNING | ERROR
AUDIODROP_LOG_LEVEL=INFO

# IP local autorizada para abrir el panel admin.
AUDIODROP_ADMIN_IP=192.168.68.83

# Secreto opcional para abrir /admin desde el campo del enlace.
# Mantener vacío en git; definirlo sólo en /etc/audiodrop/audiodrop.env.
AUDIODROP_ADMIN_ENTRY_SECRET=

# PostgreSQL para auditoría y bloqueo de IPs (formato SQLAlchemy/psycopg).
# Ejemplo: postgresql://usuario:password@192.168.100.2:5432/audiodrop
AUDIODROP_DATABASE_URL=

# reCAPTCHA v3 opcional. Si no se define el secret, el captcha queda desactivado.
AUDIODROP_RECAPTCHA_SITE_KEY=
AUDIODROP_RECAPTCHA_SECRET_KEY=
AUDIODROP_RECAPTCHA_SCORE_THRESHOLD=0.45

# Sentry
AUDIODROP_SENTRY_DSN=
AUDIODROP_SENTRY_ENVIRONMENT=production
AUDIODROP_SENTRY_TRACES_SAMPLE_RATE=0.1
AUDIODROP_SENTRY_RELEASE=
