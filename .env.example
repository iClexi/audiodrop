### VideoDrop environment variables

# Public/internal service port read by the systemd unit.
AUDIODROP_PORT=3400

# Temporary working directory for media jobs. The app cleans it automatically.
AUDIODROP_WORK_DIR=/tmp/audiodrop

# Maximum segment duration in seconds. 1800 = 30 minutes.
AUDIODROP_MAX_DURATION=1800

# Log level: DEBUG | INFO | WARNING | ERROR
AUDIODROP_LOG_LEVEL=INFO

# Trusted admin source IP. Use a deployment-specific value outside Git.
AUDIODROP_ADMIN_IP=127.0.0.1

# Optional shortcut secret for opening /admin from the URL field.
# Keep empty in Git and define only in protected runtime environments.
AUDIODROP_ADMIN_ENTRY_SECRET=
AUDIODROP_ADMIN_SESSION_TTL_SECONDS=21600

# Optional accounts and user history.
AUDIODROP_SESSION_TTL_SECONDS=2592000
AUDIODROP_PASSWORD_ITERATIONS=210000

# Optional PostgreSQL audit/history/blocklist store.
# Example only: postgresql://user:password@localhost:5432/audiodrop
AUDIODROP_DATABASE_URL=

# Optional reCAPTCHA v3. If the secret is not set, captcha enforcement remains disabled.
AUDIODROP_RECAPTCHA_SITE_KEY=
AUDIODROP_RECAPTCHA_SECRET_KEY=
AUDIODROP_RECAPTCHA_SCORE_THRESHOLD=0.45

# Optional Sentry configuration.
AUDIODROP_SENTRY_DSN=
AUDIODROP_SENTRY_ENVIRONMENT=production
AUDIODROP_SENTRY_TRACES_SAMPLE_RATE=0.1
AUDIODROP_SENTRY_RELEASE=
